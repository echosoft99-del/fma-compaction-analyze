// 4) إعدادات أخذ العينات
// ─────────────────────────────────────────────────────────────────────────────
static const int SAMPLE_COUNT        = 200;   // عدد القراءات لكل إطار
static const int SAMPLE_DELAY_MS     = 5;     // تأخير بين القراءات (ms)
static const int CALIBRATION_SAMPLES = 400;   // عينات المعايرة الأولية

// ─────────────────────────────────────────────────────────────────────────────
// 5) عتبة كشف مرور المدحلة
//    إذا كان RMS > COMPACTION_THRESHOLD  →  يُعتبر أن المدحلة تمر
//    الكشف بالحافة الصاعدة (rising edge) لمنع تعداد متكرر
// ─────────────────────────────────────────────────────────────────────────────
static const float COMPACTION_THRESHOLD = 1.5f;  // g

// ─────────────────────────────────────────────────────────────────────────────
// 6) معاملات الدمك المرجعية
// ─────────────────────────────────────────────────────────────────────────────
static const float REF_INITIAL = 78.0f;   // نسبة الدمك الابتدائية %
static const float REF_FINAL   = 98.5f;   // نسبة الدمك النهائية المرجعية %
static const int   REF_PASSES  = 8;       // عدد التمريرات المرجعية

// ─────────────────────────────────────────────────────────────────────────────
// 7) الكائنات العامة
// ─────────────────────────────────────────────────────────────────────────────
WebServer   server(80);
Preferences prefs;

String activeSSID;
String activePass;

// ─────────────────────────────────────────────────────────────────────────────
// 8) متغيرات الحساس والعداد
// ─────────────────────────────────────────────────────────────────────────────
struct SensorFrame {
  float    ax, ay, az;
  float    gx, gy, gz;
  float    tempC;
  float    rms;
  float    peak;
  float    dominantHz;
  float    gyroRms;
  uint32_t uptimeMs;
};

// متغيرات المعايرة
float accelOffsetX = 0.0f, accelOffsetY = 0.0f, accelOffsetZ = 0.0f;
float gyroOffsetX  = 0.0f, gyroOffsetY  = 0.0f, gyroOffsetZ  = 0.0f;

// عداد التمريرات وكشف الحافة
volatile int  compactionPasses    = 0;
volatile bool prevAboveThreshold  = false;  // حالة الدورة السابقة
volatile bool isTracking          = false;  // وضع التتبع النشط

unsigned long lastSerialMs = 0;
bool hasSavedWifiConfig = false;

