// 21) setup
// ─────────────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println();
  Serial.println("====================================================================");
  Serial.println("  مراقبة دمك التربة FMA - DOIT ESP32 DEVKIT V1 + MPU9250/6500");
  Serial.println("====================================================================");

  loadWifiCredentials();

  Wire.begin(I2C_SDA_PIN, I2C_SCL_PIN);
  Wire.setClock(400000);

  if (!sensorExists()) {
    Serial.println("[ERROR] ❌ لم يُعثر على الحساس عند 0x68.");
    Serial.println("[ERROR] تحقق من توصيلات VCC/GND/SDA/SCL/AD0.");
    while (true) delay(1000);
  }
  Serial.println("[MPU] ✅ تم الكشف عن الحساس MPU-9250/6500.");

  initMPU();
  calibrateSensor();

  Serial.printf("[HTTP] واجهة الويب المدمجة المضغوطة جاهزة (%u bytes gz)\n", (unsigned)INDEX_HTML_GZ_LEN);

  setupWiFi();
  setupServer();

  Serial.println("====================================================================");
  Serial.println("  الجهاز جاهز للاستخدام الميداني.");
  Serial.printf ("  عتبة كشف التمرير: %.2f g\n", COMPACTION_THRESHOLD);
  Serial.printf ("  ref_initial=%.1f%%  ref_final=%.1f%%  ref_passes=%d\n",
                 REF_INITIAL, REF_FINAL, REF_PASSES);
  Serial.println("====================================================================");
}

