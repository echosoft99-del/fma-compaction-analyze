 /*
=================================================================================
  مراقبة دمك التربة FMA - الإصدار الميداني النهائي
  Hardware : DOIT ESP32 DEVKIT V1
  Sensor   : MPU9250 / MPU6500 / MPU9255   (I2C  SDA=GPIO21  SCL=GPIO22)
  Regulator: HT7333-A  3.3V
  Charger  : TP4056  +  Li-ion 3.7 V
=================================================================================
  Arduino IDE 2.x:
  - Board: DOIT ESP32 DEVKIT V1
  - Partition Scheme: Huge APP
  - Required libraries:
      * لا توجد ملفات واجهة خارجية مطلوبة
=================================================================================
  المسارات :
    GET  /            -> واجهة الويب الأصلية مدمجة داخل الكود
    GET  /data        -> قراءة JSON من الحساس
    GET  /calibrate   -> إعادة المعايرة
    GET  /get-wifi    -> قراءة اسم الشبكة المحفوظة
    POST /set-wifi    -> تغيير الشبكة  (X-API-Key: FMA2024)
    POST /control     -> تحكم بالعداد  {"action":"start"/"stop"/"clear"}
    POST /reset-wifi  -> حذف شبكة Wi-Fi المحفوظة والعودة إلى AP
    POST /reboot      -> إعادة تشغيل الجهاز
    GET  /health      -> فحص صحي سريع للجهاز
=================================================================================
*/

#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <Preferences.h>
#include <math.h>

// ─────────────────────────────────────────────────────────────────────────────
// 1) ثوابت الشبكة
// ─────────────────────────────────────────────────────────────────────────────
static const char* DEFAULT_WIFI_SSID = "Ghazi";
static const char* DEFAULT_WIFI_PASS = "012345678";
static const char* AP_SSID           = "ESP32-Compaction";
