// ─────────────────────────────────────────────────────────────────────────────
// 11) أدوات I2C
// ─────────────────────────────────────────────────────────────────────────────
void writeReg(uint8_t reg, uint8_t value) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.write(value);
  Wire.endTransmission(true);
}

bool readRegs(uint8_t reg, uint8_t count, uint8_t* buf) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  if (Wire.endTransmission(false) != 0) return false;
  uint8_t n = Wire.requestFrom((int)MPU_ADDR, (int)count, (int)true);
  if (n != count) return false;
  for (uint8_t i = 0; i < count; i++) buf[i] = Wire.read();
  return true;
}

bool readRawFrame(int16_t& ax, int16_t& ay, int16_t& az,
                  int16_t& temp, int16_t& gx, int16_t& gy, int16_t& gz) {
  uint8_t raw[14];
  if (!readRegs(REG_ACCEL_XOUT_H, 14, raw)) return false;
  ax   = (int16_t)((raw[0]  << 8) | raw[1]);
  ay   = (int16_t)((raw[2]  << 8) | raw[3]);
  az   = (int16_t)((raw[4]  << 8) | raw[5]);
  temp = (int16_t)((raw[6]  << 8) | raw[7]);
  gx   = (int16_t)((raw[8]  << 8) | raw[9]);
  gy   = (int16_t)((raw[10] << 8) | raw[11]);
  gz   = (int16_t)((raw[12] << 8) | raw[13]);
  return true;
}

// ─────────────────────────────────────────────────────────────────────────────
// 12) كشف وجود الحساس وتهيئته
// ─────────────────────────────────────────────────────────────────────────────
bool sensorExists() {
  Wire.beginTransmission(MPU_ADDR);
  return (Wire.endTransmission() == 0);
}

void initMPU() {
  writeReg(REG_PWR_MGMT_1,   0x00); // تشغيل
  delay(100);
  writeReg(REG_SMPLRT_DIV,   0x04); // ~200 Hz
  writeReg(REG_CONFIG,        0x03); // DLPF
  writeReg(REG_GYRO_CONFIG,   0x08); // ±500 dps
  writeReg(REG_ACCEL_CONFIG,  0x08); // ±4g
  writeReg(REG_ACCEL_CONFIG2, 0x03); // DLPF للتسارع
  writeReg(REG_INT_PIN_CFG,   0x02);
  delay(50);
}

// ─────────────────────────────────────────────────────────────────────────────
// 13) معايرة الإزاحة الصفرية
// ─────────────────────────────────────────────────────────────────────────────
void calibrateSensor(int samples = CALIBRATION_SAMPLES) {
  float sumAx = 0, sumAy = 0, sumAz = 0;
  float sumGx = 0, sumGy = 0, sumGz = 0;
  int   valid = 0;
  Serial.println("[CAL] بدأت المعايرة... ضع الجهاز ثابتاً بدون حركة.");
  for (int i = 0; i < samples; i++) {
    int16_t rax, ray, raz, rt, rgx, rgy, rgz;
    if (readRawFrame(rax, ray, raz, rt, rgx, rgy, rgz)) {
      sumAx += (float)rax / 8192.0f;
      sumAy += (float)ray / 8192.0f;
      sumAz += (float)raz / 8192.0f;
      sumGx += (float)rgx / 65.5f;
      sumGy += (float)rgy / 65.5f;
      sumGz += (float)rgz / 65.5f;
      valid++;
    }
    delay(5);
  }
  if (valid > 0) {
    accelOffsetX = sumAx / valid;
    accelOffsetY = sumAy / valid;
    accelOffsetZ = (sumAz / valid) - 1.0f;  // إزالة الجاذبية من المحور العمودي
    gyroOffsetX  = sumGx / valid;
    gyroOffsetY  = sumGy / valid;
    gyroOffsetZ  = sumGz / valid;
  }
  Serial.println("[CAL] انتهت المعايرة بنجاح.");
  Serial.printf("[CAL] إزاحة التسارع: %.4f, %.4f, %.4f g\n",
                accelOffsetX, accelOffsetY, accelOffsetZ);
  Serial.printf("[CAL] إزاحة الجيروسكوب: %.4f, %.4f, %.4f dps\n",
                gyroOffsetX, gyroOffsetY, gyroOffsetZ);
}

// ─────────────────────────────────────────────────────────────────────────────
// 14) التقاط إطار حساس معالج
//     + كشف التمريرات من الحافة الصاعدة للـ RMS
// ─────────────────────────────────────────────────────────────────────────────
SensorFrame captureFrame() {
  SensorFrame f{};
  float sumDyn2 = 0, sumGyr2 = 0, peak = 0;
  int   crossings = 0;
  float prevDyn = 0;
  bool  hasPrev = false;

  float lastAx = 0, lastAy = 0, lastAz = 1;
  float lastGx = 0, lastGy = 0, lastGz = 0;
  float lastT  = 25;

  for (int i = 0; i < SAMPLE_COUNT; i++) {
    int16_t rax, ray, raz, rt, rgx, rgy, rgz;
    if (readRawFrame(rax, ray, raz, rt, rgx, rgy, rgz)) {
      float ax = (float)rax / 8192.0f - accelOffsetX;
      float ay = (float)ray / 8192.0f - accelOffsetY;
      float az = (float)raz / 8192.0f - accelOffsetZ;
      float gx = (float)rgx / 65.5f   - gyroOffsetX;
      float gy = (float)rgy / 65.5f   - gyroOffsetY;
      float gz = (float)rgz / 65.5f   - gyroOffsetZ;
      float tempC = (float)rt / 333.87f + 21.0f;

      float mag  = sqrtf(ax*ax + ay*ay + az*az);
      float dyn  = mag - 1.0f;
      float gyroMag = sqrtf(gx*gx + gy*gy + gz*gz);

      sumDyn2 += dyn * dyn;
      sumGyr2 += gyroMag * gyroMag;
      if (fabsf(dyn) > peak) peak = fabsf(dyn);

      if (hasPrev && ((dyn >= 0 && prevDyn < 0) || (dyn < 0 && prevDyn >= 0)))
        crossings++;

      prevDyn = dyn; hasPrev = true;
      lastAx = ax; lastAy = ay; lastAz = az;
      lastGx = gx; lastGy = gy; lastGz = gz;
      lastT  = tempC;
    }
    delay(SAMPLE_DELAY_MS);
  }

  float dur = (SAMPLE_COUNT * SAMPLE_DELAY_MS) / 1000.0f;
  f.ax         = lastAx;   f.ay  = lastAy;   f.az  = lastAz;
  f.gx         = lastGx;   f.gy  = lastGy;   f.gz  = lastGz;
  f.tempC      = lastT;
  f.rms        = sqrtf(sumDyn2 / SAMPLE_COUNT);
  f.peak       = peak;
  f.gyroRms    = sqrtf(sumGyr2 / SAMPLE_COUNT);
  f.dominantHz = (crossings / 2.0f) / max(dur, 0.001f);
  f.uptimeMs   = millis();

  // ── كشف تمرير المدحلة بالحافة الصاعدة ──
  bool currentlyAbove = (f.rms > COMPACTION_THRESHOLD);
  if (currentlyAbove && !prevAboveThreshold && isTracking) {
    compactionPasses++;
    Serial.printf("[PASS] تمرير رقم %d  RMS=%.3f\n", compactionPasses, f.rms);
  }
  prevAboveThreshold = currentlyAbove;

  return f;
}

// ─────────────────────────────────────────────────────────────────────────────
// 15) حساب نسبة الدمك
// ─────────────────────────────────────────────────────────────────────────────
float calcCompaction(int passes) {
  float ratio = (REF_PASSES > 0) ? min(1.0f, (float)passes / (float)REF_PASSES) : 0.0f;
  return REF_INITIAL + (REF_FINAL - REF_INITIAL) * ratio;
}

String compStatus(float comp) {
  if (comp < 95.0f)   return "غير مقبول";
  if (comp <= 100.0f) return "مقبول";
  return "دمك مفرط";
}
String compColor(float comp) {
  if (comp < 95.0f)   return "#e74c3c";
  if (comp <= 100.0f) return "#27ae60";
  return "#2980b9";
}

// ─────────────────────────────────────────────────────────────────────────────
// 16) بناء JSON للاستجابة
// ─────────────────────────────────────────────────────────────────────────────
String buildJson(const SensorFrame& f) {
  float comp    = calcCompaction(compactionPasses);
  String status = compStatus(comp);
  String color  = compColor(comp);

  String mode, ssid_str, ip_str;
  if (WiFi.getMode() == WIFI_AP) {
    mode     = "AP";
    ssid_str = String(AP_SSID);
    ip_str   = WiFi.softAPIP().toString();
  } else {
    mode     = "STA";
    ssid_str = WiFi.SSID();
    ip_str   = WiFi.localIP().toString();
  }

  String out;
  out.reserve(640);
  out += "{\"ax\":"; out += String(f.ax, 4);
  out += ",\"ay\":"; out += String(f.ay, 4);
  out += ",\"az\":"; out += String(f.az, 4);
  out += ",\"gx\":"; out += String(f.gx, 3);
  out += ",\"gy\":"; out += String(f.gy, 3);
  out += ",\"gz\":"; out += String(f.gz, 3);
  out += ",\"temp_c\":"; out += String(f.tempC, 2);
  out += ",\"rms\":"; out += String(f.rms, 4);
  out += ",\"peak\":"; out += String(f.peak, 4);
  out += ",\"dominant_hz\":"; out += String(f.dominantHz, 3);
  out += ",\"gyro_rms\":"; out += String(f.gyroRms, 4);
  out += ",\"uptime_ms\":"; out += String(f.uptimeMs);
  out += ",\"passes\":"; out += String(compactionPasses);
  out += ",\"compaction_percent\":"; out += String(comp, 2);
  out += ",\"compaction_status\":\""; out += status; out += "\"";
  out += ",\"point_color\":\""; out += color; out += "\"";
  out += ",\"threshold_g\":"; out += String(COMPACTION_THRESHOLD, 2);
  out += ",\"wifi_mode\":\""; out += mode; out += "\"";
  out += ",\"ssid\":\""; out += ssid_str; out += "\"";
  out += ",\"ip\":\""; out += ip_str; out += "\"";
  out += ",\"tracking\":"; out += (isTracking ? "true" : "false");
  out += ",\"wifi_saved\":"; out += (hasSavedWifiConfig ? "true" : "false");
  out += ",\"free_heap\":"; out += String(ESP.getFreeHeap());
  out += ",\"min_free_heap\":"; out += String(ESP.getMinFreeHeap());
  out += ",\"ap_ssid\":\""; out += String(AP_SSID); out += "\"";
  out += "}";
  return out;
}

