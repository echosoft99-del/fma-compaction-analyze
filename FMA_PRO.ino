void handleRoot() {
  addCorsHeaders();
  server.sendHeader("Content-Encoding", "gzip");
  server.send_P(200, "text/html; charset=utf-8", reinterpret_cast<const char*>(INDEX_HTML_GZ), INDEX_HTML_GZ_LEN);
}

void handleData() {
  SensorFrame frame = captureFrame();
  String payload    = buildJson(frame);
  addCorsHeaders();
  server.send(200, "application/json", payload);

  if (millis() - lastSerialMs > 2000) {
    lastSerialMs = millis();
    float comp = calcCompaction(compactionPasses);
    Serial.printf("[DATA] RMS=%.3f Peak=%.3f Hz=%.2f P=%d Comp=%.1f%%\n",
                  frame.rms, frame.peak, frame.dominantHz, compactionPasses, comp);
  }
}

void handleCalibrate() {
  calibrateSensor();
  addCorsHeaders();
  server.send(200, "application/json",
    "{\"status\":\"ok\",\"message\":\"تمت إعادة المعايرة\"}");
}

String jsonEscape(const String& in) {
  String out;
  out.reserve(in.length() + 8);
  for (size_t i = 0; i < in.length(); ++i) {
    char c = in[i];
    if (c == '\\' || c == '"') out += '\\';
    out += c;
  }
  return out;
}

String extractJsonString(const String& body, const String& key) {
  String token = String("\"") + key + "\"";
  int p = body.indexOf(token);
  if (p < 0) return "";
  p = body.indexOf(':', p + token.length());
  if (p < 0) return "";
  ++p;
  while (p < (int)body.length() && isspace((unsigned char)body[p])) ++p;
  if (p >= (int)body.length()) return "";
  if (body[p] == '"') {
    ++p;
    String out;
    while (p < (int)body.length()) {
      char c = body[p++];
      if (c == '\\' && p < (int)body.length()) {
        out += body[p++];
        continue;
      }
      if (c == '"') break;
      out += c;
    }
    return out;
  }
  int e = p;
  while (e < (int)body.length() && body[e] != ',' && body[e] != '}' && !isspace((unsigned char)body[e])) ++e;
  return body.substring(p, e);
}

void handleGetWifi() {
  addCorsHeaders();
  String mode = (WiFi.getMode() == WIFI_AP) ? "AP" : "STA";
  String ip = (WiFi.getMode() == WIFI_AP) ? WiFi.softAPIP().toString() : WiFi.localIP().toString();
  String out = String("{\"ssid\":\"") + jsonEscape(activeSSID)
             + "\",\"mode\":\"" + mode
             + "\",\"ip\":\"" + ip
             + "\",\"saved\":" + (hasSavedWifiConfig ? "true" : "false")
             + ",\"ap_ssid\":\"" + String(AP_SSID) + "\"}";
  server.send(200, "application/json", out);
}

void handleSetWifiOptions() {
  addCorsHeaders();
  server.send(204, "text/plain", "");
}

bool checkApiKey() {
  if (!server.hasHeader("X-API-Key") || server.header("X-API-Key") != String(API_KEY)) {
    server.send(403, "application/json", "{\"status\":\"error\",\"message\":\"مفتاح API غير صحيح\"}");
    return false;
  }
  return true;
}

void handleSetWifi() {
  addCorsHeaders();
  if (!checkApiKey()) {
    Serial.println("[WIFI] رُفض طلب تغيير الشبكة: مفتاح خاطئ.");
    return;
  }
  if (!server.hasArg("plain")) {
    server.send(400, "application/json",
      "{\"status\":\"error\",\"message\":\"لا توجد بيانات JSON\"}");
    return;
  }
  String body = server.arg("plain");
  String newSSID = extractJsonString(body, "ssid");
  String newPass = extractJsonString(body, "password");
  if (newSSID.length() == 0 && body.indexOf("\"ssid\"") >= 0) {
    newSSID = extractJsonString(body, "ssid");
  }
  if (newSSID.length() == 0) {
    server.send(400, "application/json",
      "{\"status\":\"error\",\"message\":\"الحقول ssid/password مفقودة\"}");
    return;
  }
  if (newSSID.length() == 0) {
    server.send(400, "application/json",
      "{\"status\":\"error\",\"message\":\"اسم الشبكة فارغ\"}");
    return;
  }
  prefs.begin("wifi-cfg", false);
  prefs.putString("wifi_ssid", newSSID);
  prefs.putString("wifi_pass", newPass);
  prefs.end();
  activeSSID = newSSID;
  activePass = newPass;
  hasSavedWifiConfig = true;
  Serial.printf("[WIFI] شبكة جديدة محفوظة: %s\n", newSSID.c_str());
  server.send(200, "application/json",
    "{\"status\":\"ok\",\"message\":\"تم الحفظ، جاري إعادة التشغيل...\"}");
  delay(200);
  ESP.restart();
}

void handleResetWifi() {
  addCorsHeaders();
  if (!checkApiKey()) return;
  clearSavedWifiCredentials();
  server.send(200, "application/json",
    "{\"status\":\"ok\",\"message\":\"تم حذف شبكة Wi-Fi المحفوظة، سيعاد التشغيل إلى وضع AP\"}");
  delay(200);
  ESP.restart();
}

void handleReboot() {
  addCorsHeaders();
  if (!checkApiKey()) return;
  server.send(200, "application/json",
    "{\"status\":\"ok\",\"message\":\"تم إرسال أمر إعادة التشغيل\"}");
  delay(200);
  ESP.restart();
}

void handleHealth() {
  addCorsHeaders();
  String mode = (WiFi.getMode() == WIFI_AP) ? "AP" : "STA";
  String ip = (WiFi.getMode() == WIFI_AP) ? WiFi.softAPIP().toString() : WiFi.localIP().toString();
  String out;
  out.reserve(320);
  out += "{\"status\":\"ok\"";
  out += ",\"mode\":\""; out += mode; out += "\"";
  out += ",\"ssid\":\""; out += jsonEscape(activeSSID); out += "\"";
  out += ",\"ip\":\""; out += ip; out += "\"";
  out += ",\"tracking\":"; out += (isTracking ? "true" : "false");
  out += ",\"passes\":"; out += String(compactionPasses);
  out += ",\"wifi_saved\":"; out += (hasSavedWifiConfig ? "true" : "false");
  out += ",\"free_heap\":"; out += String(ESP.getFreeHeap());
  out += ",\"min_free_heap\":"; out += String(ESP.getMinFreeHeap());
  out += ",\"sensor_present\":"; out += (sensorExists() ? "true" : "false");
  out += ",\"uptime_ms\":"; out += String(millis());
  out += "}";
  server.send(200, "application/json", out);
}

void handleControl() {
  addCorsHeaders();
  if (!server.hasArg("plain")) {
    server.send(400, "application/json",
      "{\"status\":\"error\",\"message\":\"لا توجد بيانات\"}");
    return;
  }
  String body = server.arg("plain");
  String action = extractJsonString(body, "action");
  if (action.length() == 0) {
    server.send(400, "application/json",
      "{\"status\":\"error\",\"message\":\"JSON خاطئ\"}");
    return;
  }
  if (action == "start") {
    isTracking = true;
    Serial.println("[CTRL] بدأ التتبع.");
  } else if (action == "stop") {
    isTracking = false;
    Serial.println("[CTRL] توقف التتبع.");
  } else if (action == "clear") {
    compactionPasses   = 0;
    prevAboveThreshold = false;
    isTracking         = false;
    Serial.println("[CTRL] تم المسح وتصفير العداد.");
  }
  String resp = "{\"status\":\"ok\",\"action\":\"" + action
              + "\",\"passes\":" + String(compactionPasses)
              + ",\"tracking\":" + (isTracking ? "true" : "false") + "}";
  server.send(200, "application/json", resp);
}

void handleControlOptions() {
  addCorsHeaders();
  server.send(204, "text/plain", "");
}

void handleNotFound() {
  addCorsHeaders();
  server.send(404, "application/json", "{\"status\":\"error\",\"message\":\"Not Found\"}");
}

// ─────────────────────────────────────────────────────────────────────────────
// 18) إعداد الخادم
// ─────────────────────────────────────────────────────────────────────────────
void setupServer() {
  const char* hdrs[] = {"X-API-Key", "Content-Type"};
  server.collectHeaders(hdrs, 2);

  server.on("/",           HTTP_GET,     handleRoot);
  server.on("/data",       HTTP_GET,     handleData);
  server.on("/health",     HTTP_GET,     handleHealth);
  server.on("/calibrate",  HTTP_GET,     handleCalibrate);
  server.on("/get-wifi",   HTTP_GET,     handleGetWifi);
  server.on("/set-wifi",   HTTP_OPTIONS, handleSetWifiOptions);
  server.on("/set-wifi",   HTTP_POST,    handleSetWifi);
  server.on("/reset-wifi", HTTP_OPTIONS, handleSetWifiOptions);
  server.on("/reset-wifi", HTTP_POST,    handleResetWifi);
  server.on("/reboot",     HTTP_OPTIONS, handleSetWifiOptions);
  server.on("/reboot",     HTTP_POST,    handleReboot);
  server.on("/control",    HTTP_OPTIONS, handleControlOptions);
  server.on("/control",    HTTP_POST,    handleControl);
  server.onNotFound(handleNotFound);

  server.begin();
  Serial.println("[HTTP] الخادم يعمل على المنفذ 80.");
}

// ─────────────────────────────────────────────────────────────────────────────
// 19) تحميل إعدادات Wi-Fi
// ─────────────────────────────────────────────────────────────────────────────
void loadWifiCredentials() {
  prefs.begin("wifi-cfg", true);
  String ss = prefs.getString("wifi_ssid", "");
  String ps = prefs.getString("wifi_pass", "");
  prefs.end();
  if (ss.length() > 0) {
    activeSSID = ss;
    activePass = ps;
    hasSavedWifiConfig = true;
    Serial.printf("[PREFS] تم تحميل الشبكة المحفوظة: %s\n", activeSSID.c_str());
  } else {
    activeSSID = String(DEFAULT_WIFI_SSID);
    activePass = String(DEFAULT_WIFI_PASS);
    hasSavedWifiConfig = false;
    Serial.println("[PREFS] لا توجد شبكة محفوظة، تم استخدام القيم الافتراضية.");
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// 20) إعداد الشبكة
// ─────────────────────────────────────────────────────────────────────────────
void setupWiFi() {
  WiFi.mode(WIFI_STA);
  WiFi.begin(activeSSID.c_str(), activePass.c_str());
  Serial.printf("[WIFI] محاولة الاتصال بـ: %s\n", activeSSID.c_str());

  unsigned long t0 = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - t0 < 12000) {
    delay(500); Serial.print(".");
  }
  Serial.println();

  if (WiFi.status() == WL_CONNECTED) {
    Serial.printf("[WIFI] ✅ متصل | IP: %s\n", WiFi.localIP().toString().c_str());
  } else {
    Serial.println("[WIFI] ❌ فشل الاتصال، تشغيل نقطة وصول AP...");
    WiFi.disconnect(true, true);
    delay(300);
    WiFi.mode(WIFI_AP);
    WiFi.softAP(AP_SSID, AP_PASS);
    Serial.printf("[WIFI] AP جاهز | IP: %s | SSID: %s | Pass: %s\n",
                  WiFi.softAPIP().toString().c_str(), AP_SSID, AP_PASS);
  }
}

